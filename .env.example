# Cloudflare R2 对象存储（推荐，主存储后端）
# 获取方式：Cloudflare Dashboard → R2 → 创建 bucket + API token
# R2_PUBLIC_URL 可选，配置后启用自定义域名（生产推荐，避免 r2.dev 速率限制）
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=

