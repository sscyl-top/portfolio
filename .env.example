# 腾讯云 COS 对象存储（可选，配置后优先于 Supabase Storage）
# 配置后可突破 Supabase 免费版 50MB 单文件限制，且国内访问更快
# 获取方式：https://console.cloud.tencent.com/cos
# Bucket 格式：name-appid（如 portfolio-1234567890）
# Region 示例：ap-guangzhou、ap-shanghai、ap-beijing
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=
COS_REGION=
# 可选：如果配置了 CDN 加速域名，填这里（如 cdn.example.com）
COS_CDN_DOMAIN=
